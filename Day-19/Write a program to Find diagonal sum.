# Program to find the sum of diagonals of a matrix

A = [
    [1, 2, 3],
    [4, 5, 6],
    [7, 8, 9]
]

n = len(A)

primary_sum = 0
secondary_sum = 0

for i in range(n):
    primary_sum += A[i][i]            # Primary diagonal
    secondary_sum += A[i][n - i - 1]  # Secondary diagonal

print("Primary Diagonal Sum:", primary_sum)
print("Secondary Diagonal Sum:", secondary_sum)
print("Total Diagonal Sum:", primary_sum + secondary_sum)
