# Write a program to Union of arrays. 

n1 = int(input("Enter number of elements in first array: "))
arr1 = [int(input(f"Enter element {i+1} of first array: ")) for i in range(n1)]

n2 = int(input("Enter number of elements in second array: "))
arr2 = [int(input(f"Enter element {i+1} of second array: ")) for i in range(n2)]

union_arr = []
for x in arr1 + arr2:
    if x not in union_arr:
        union_arr.append(x)

print("Union of arrays:", union_arr)
