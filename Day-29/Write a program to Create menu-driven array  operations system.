# Menu-Driven Array Operations System

arr = []

while True:
    print("\n1. Insert  2. Delete  3. Search  4. Display  5. Exit")
    choice = int(input("Enter choice: "))

    if choice == 1:
        val = int(input("Enter value to insert: "))
        arr.append(val)
        print("Inserted.")
    elif choice == 2:
        val = int(input("Enter value to delete: "))
        if val in arr:
            arr.remove(val)
            print("Deleted.")
        else:
            print("Not found.")
    elif choice == 3:
        val = int(input("Enter value to search: "))
        print("Found." if val in arr else "Not found.")
    elif choice == 4:
        print("Array:", arr)
    elif choice == 5:
        break
    else:
        print("Invalid choice")
